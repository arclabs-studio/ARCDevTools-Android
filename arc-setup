#!/bin/bash
# ARCDevTools-Android Setup Script
# Version: 1.2.0
#
# Installs ARCDevTools-Android configuration files, git hooks, and generates
# Makefile for ARC Labs Studio Android projects.

set -e

VERSION="1.2.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(pwd)"

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# --- Utility Functions ---

print_info() {
  echo -e "${CYAN}$1${NC}"
}

print_success() {
  echo -e "${GREEN}  $1${NC}"
}

print_error() {
  echo -e "${RED}  $1${NC}"
}

print_warning() {
  echo -e "${YELLOW}  $1${NC}"
}

# --- Parse Arguments ---

WITH_WORKFLOWS=false
NO_WORKFLOWS=false
SHOW_HELP=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --with-workflows)
      WITH_WORKFLOWS=true
      shift
      ;;
    --no-workflows)
      NO_WORKFLOWS=true
      shift
      ;;
    --help|-h)
      SHOW_HELP=true
      shift
      ;;
    *)
      shift
      ;;
  esac
done

if [ "$SHOW_HELP" = true ]; then
  echo ""
  print_info "ARCDevTools-Android Setup v${VERSION}"
  echo ""
  echo "Usage: arc-setup [options]"
  echo ""
  echo "Options:"
  echo "  --with-workflows  Install GitHub Actions workflows (non-interactive)"
  echo "  --no-workflows    Skip GitHub Actions workflows (non-interactive)"
  echo "  --help, -h        Show this help message"
  echo ""
  echo "Examples:"
  echo "  ./ARCDevTools-Android/arc-setup                  # Interactive mode"
  echo "  ./ARCDevTools-Android/arc-setup --with-workflows # CI mode with workflows"
  echo "  ./ARCDevTools-Android/arc-setup --no-workflows   # CI mode without workflows"
  echo ""
  exit 0
fi

# --- Banner ---

echo ""
print_info "ARCDevTools-Android Setup v${VERSION}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# --- Detect Android Project ---

print_info "Detecting project type..."

HAS_GRADLEW=false
HAS_BUILD_GRADLE=false

if [ -f "$PROJECT_ROOT/gradlew" ]; then
  HAS_GRADLEW=true
fi

if [ -f "$PROJECT_ROOT/build.gradle.kts" ] || [ -f "$PROJECT_ROOT/build.gradle" ]; then
  HAS_BUILD_GRADLE=true
fi

if [ "$HAS_GRADLEW" = false ] && [ "$HAS_BUILD_GRADLE" = false ]; then
  print_error "No gradlew or build.gradle.kts detected"
  print_error "Run this script from your Android project root directory"
  exit 1
fi

print_success "Android project detected"

# --- Copy .editorconfig ---

echo ""
print_info "Copying configurations..."

EDITORCONFIG_SOURCE="$SCRIPT_DIR/configs/.editorconfig"
if [ -f "$EDITORCONFIG_SOURCE" ]; then
  cp "$EDITORCONFIG_SOURCE" "$PROJECT_ROOT/.editorconfig"
  print_success ".editorconfig copied to project root"
else
  print_warning ".editorconfig not found in ARCDevTools-Android"
fi

# --- Copy detekt configs ---

DETEKT_CONFIG_DIR="$PROJECT_ROOT/config/detekt"
mkdir -p "$DETEKT_CONFIG_DIR"

DETEKT_SOURCE="$SCRIPT_DIR/configs/detekt.yml"
if [ -f "$DETEKT_SOURCE" ]; then
  cp "$DETEKT_SOURCE" "$DETEKT_CONFIG_DIR/detekt.yml"
  print_success "detekt.yml copied to config/detekt/"
else
  print_warning "detekt.yml not found in ARCDevTools-Android"
fi

DETEKT_COMPOSE_SOURCE="$SCRIPT_DIR/configs/detekt-compose.yml"
if [ -f "$DETEKT_COMPOSE_SOURCE" ]; then
  cp "$DETEKT_COMPOSE_SOURCE" "$DETEKT_CONFIG_DIR/detekt-compose.yml"
  print_success "detekt-compose.yml copied to config/detekt/"
else
  print_warning "detekt-compose.yml not found in ARCDevTools-Android"
fi

# --- Install Git Hooks ---

echo ""
print_info "Installing git hooks..."

GIT_DIR="$PROJECT_ROOT/.git"
if [ -d "$GIT_DIR" ]; then
  bash "$SCRIPT_DIR/hooks/install-hooks.sh"
else
  print_warning ".git not found (is this a git repository?)"
fi

# --- Generate Makefile ---

echo ""
print_info "Generating Makefile..."

ARCDEVTOOLS_DIR=$(basename "$SCRIPT_DIR")

cat > "$PROJECT_ROOT/Makefile" << MAKEFILE
# ARCDevTools-Android Makefile
# Auto-generated by arc-setup v${VERSION} - Do not edit manually

.PHONY: help lint format fix test setup hooks clean

help:
	@echo "ARCDevTools-Android - Available commands:"
	@echo "  make lint      - Run detekt and ktlint"
	@echo "  make format    - Run ktlint format (dry-run)"
	@echo "  make fix       - Apply ktlint format"
	@echo "  make test      - Run unit tests"
	@echo "  make setup     - Re-install hooks and configs"
	@echo "  make hooks     - Re-install git hooks only"
	@echo "  make clean     - Clean build artifacts"

lint:
	@./gradlew detekt ktlintCheck --daemon

format:
	@./gradlew ktlintCheck --daemon

fix:
	@./gradlew ktlintFormat --daemon

test:
	@./gradlew testDebugUnitTest --daemon

setup:
	@./${ARCDEVTOOLS_DIR}/arc-setup

hooks:
	@./${ARCDEVTOOLS_DIR}/hooks/install-hooks.sh

clean:
	@./gradlew clean
	@echo "Build artifacts removed"

MAKEFILE

print_success "Makefile generated"

# --- Workflows ---

install_workflows() {
  echo ""
  print_info "Copying GitHub Actions workflows..."

  WORKFLOWS_SOURCE="$SCRIPT_DIR/workflows"
  GITHUB_WORKFLOWS_DIR="$PROJECT_ROOT/.github/workflows"
  mkdir -p "$GITHUB_WORKFLOWS_DIR"

  if [ -d "$WORKFLOWS_SOURCE" ]; then
    for workflow in "$WORKFLOWS_SOURCE"/*.yml; do
      if [ -f "$workflow" ]; then
        FILENAME=$(basename "$workflow")
        cp "$workflow" "$GITHUB_WORKFLOWS_DIR/$FILENAME"
        print_success "$FILENAME"
      fi
    done
  else
    print_warning "workflows/ not found in ARCDevTools-Android"
  fi

  # Copy templates
  TEMPLATES_SOURCE="$SCRIPT_DIR/templates"
  GITHUB_DIR="$PROJECT_ROOT/.github"

  if [ -d "$TEMPLATES_SOURCE" ]; then
    # Copy PR template
    if [ -f "$TEMPLATES_SOURCE/PULL_REQUEST_TEMPLATE.md" ]; then
      cp "$TEMPLATES_SOURCE/PULL_REQUEST_TEMPLATE.md" "$GITHUB_DIR/PULL_REQUEST_TEMPLATE.md"
      print_success "PULL_REQUEST_TEMPLATE.md"
    fi

    # Copy issue templates
    if [ -d "$TEMPLATES_SOURCE/ISSUE_TEMPLATE" ]; then
      mkdir -p "$GITHUB_DIR/ISSUE_TEMPLATE"
      for template in "$TEMPLATES_SOURCE/ISSUE_TEMPLATE"/*.md; do
        if [ -f "$template" ]; then
          FILENAME=$(basename "$template")
          cp "$template" "$GITHUB_DIR/ISSUE_TEMPLATE/$FILENAME"
          print_success "$FILENAME"
        fi
      done
    fi
  fi
}

if [ "$WITH_WORKFLOWS" = true ]; then
  install_workflows
elif [ "$NO_WORKFLOWS" = false ]; then
  echo ""
  read -p "Do you want to copy GitHub Actions workflows? [y/N]: " response
  case "$response" in
    [yY]|[yY][eE][sS])
      install_workflows
      ;;
  esac
fi

# --- Final Summary ---

echo ""
echo -e "${GREEN}ARCDevTools-Android v${VERSION} configured successfully${NC}"
echo ""
echo -e "${BLUE}Installed configurations:${NC}"
echo "   .editorconfig (v${VERSION})"
echo "   config/detekt/detekt.yml (v${VERSION})"
echo "   config/detekt/detekt-compose.yml (v${VERSION})"
echo "   Makefile (v${VERSION})"
echo ""
echo -e "${BLUE}Next steps:${NC}"
echo "   1. Run: make lint"
echo "   2. Run: make format"
echo "   3. Run: make test"
echo "   4. Make a commit to test pre-commit hook"
echo ""
echo -e "${BLUE}See available commands: make help${NC}"
echo ""
