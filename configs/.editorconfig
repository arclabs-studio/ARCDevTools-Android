# ARCDevTools-Android EditorConfig
# https://editorconfig.org
# https://pinterest.github.io/ktlint/latest/rules/configuration-ktlint/
# Version: 1.1.0

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.{kt,kts}]
# ktlint configuration
ktlint_code_style = intellij_idea

# Function signatures
ktlint_function_signature_rule_force_multiline_when_parameter_count_greater_or_equal_than = 3
ktlint_function_signature_body_expression_wrapping = multiline

# Naming conventions
ktlint_standard_package-name = enabled
ktlint_standard_filename = enabled
ktlint_standard_property-naming = enabled

# Import ordering
ktlint_standard_import-ordering = enabled
ktlint_standard_no-wildcard-imports = enabled

# no-unused-imports: disabled by default since ktlint 1.7.0 (causes issues).
# Enable explicitly if desired.
ktlint_standard_no-unused-imports = enabled

# Blank lines
ktlint_standard_no-blank-line-before-rbrace = enabled
ktlint_standard_no-consecutive-blank-lines = enabled

# Trailing commas
ktlint_standard_trailing-comma-on-call-site = enabled
ktlint_standard_trailing-comma-on-declaration-site = enabled

# Wrapping
ktlint_standard_argument-list-wrapping = enabled
ktlint_standard_parameter-list-wrapping = enabled
ktlint_standard_wrapping = enabled
ktlint_standard_multiline-expression-wrapping = enabled

# Context receiver wrapping (ktlint 1.7.0+)
ktlint_standard_context-receiver-wrapping = enabled

# Modifier order (ktlint 1.7.0+, includes context receivers)
ktlint_standard_modifier-order = enabled

# Compose rules (requires ktlint-compose-rules plugin)
ktlint_compose_composable-function-naming = enabled
ktlint_compose_modifier-missing-check = enabled
ktlint_compose_modifier-not-used-at-root = enabled
ktlint_compose_multiple-emitters-check = enabled
ktlint_compose_mutable-state-param-check = enabled
ktlint_compose_remember-missing-check = enabled
ktlint_compose_unstable-collections = enabled
ktlint_compose_vm-forwarding-check = enabled

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{yml,yaml}]
indent_size = 2

[*.xml]
indent_size = 4

[*.{gradle,gradle.kts}]
indent_size = 4

[*.json]
indent_size = 2

[Makefile]
indent_style = tab
